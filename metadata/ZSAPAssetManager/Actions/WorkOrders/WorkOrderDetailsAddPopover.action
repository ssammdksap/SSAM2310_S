{
	"_Type": "Action.Type.PopoverMenu",
	"PopoverItems": [
		{
			"Title": "$(L,add_order)",
			"OnPress": "/SAPAssetManager/Rules/WorkOrders/FollowUpWorkOrderCreateNav.js",
			"Visible": "/SAPAssetManager/Rules/UserAuthorizations/WorkOrders/EnableWorkOrderCreateFromWorkOrder.js"
		},
		{
			"Title": "$(L,add_operation)",
			"OnPress": "/SAPAssetManager/Rules/WorkOrders/Operations/CreateUpdate/WorkOrderOperationCreateNav.js",
			"Visible": false
		},
		{
			"Title": "$(L,install_meter)",
			"OnPress": "/SAPAssetManager/Rules/Meter/CreateUpdate/MeterInstallUpdateNav.js",
			"Visible": "/SAPAssetManager/Rules/WorkOrders/Meter/Details/AllowMeterCreate.js"
		},
		{
			"Title": "$(L,add_part)",
			"OnPress": "/SAPAssetManager/Rules/Parts/CreateUpdate/PartCreateNav.js",
			"Visible": "/SAPAssetManager/Rules/UserAuthorizations/WorkOrders/EnableWorkOrderEdit.js"
		},
		{
			"Title": "$(L, add_note)",
			"OnPress": "/SAPAssetManager/Rules/Notes/NoteCreateNav.js",
			"Visible": "/ZSAPAssetManager/Rules/Notifications/ZIsNotGasConv.js"
		},
		{
			"Title": "$(L,add_notification)",
			"OnPress": "/SAPAssetManager/Rules/WorkOrders/WorkOrderNotificationCreateNav.js",
			"Visible": "/ZSAPAssetManager/Rules/WorkOrders/ZSerialNumberAddVisible.js"
		},
		{
			"Title": "$(L,add_reminder)",
			"OnPress": "/SAPAssetManager/Rules/Reminders/ReminderCreateNav.js",
			"Visible": false
		},
		{
			"Title": "$(L,take_readings)",
			"OnPress": "/SAPAssetManager/Rules/Measurements/Points/MeasuringPointsDataEntryNavWrapper.js",
			"Visible": "/SAPAssetManager/Rules/Measurements/Points/MeasuringPointsTakeReadingsIsVisible.js"
		},
		{
			"Title": "$(L,add_expense)",
			"OnPress": "/SAPAssetManager/Rules/Expense/CreateUpdate/ExpenseCreateNav.js",
			"Visible": "/SAPAssetManager/Rules/Expense/CreateUpdate/IsAllowedExpenseCreate.js"
		},
		{
			"Title": "$(L,add_mileage)",
			"OnPress": "/SAPAssetManager/Rules/ServiceOrders/Mileage/MileageAddNavCheckOnlyUnsavedChanges.js",
			"Visible": "/SAPAssetManager/Rules/ServiceOrders/Mileage/MileageAddIsEnabled.js"
		},
		{
			"Title": "$(L,generate_service_report)",
			"OnPress": "/SAPAssetManager/Rules/PDF/PDFGenerate.js",
			"Visible": "/SAPAssetManager/Rules/PDF/IsPDFAllowedForOrder.js"
		},
		{
			"Title": "$(L,add_attachment)",
			"OnPress": "/SAPAssetManager/Rules/Documents/Create/DocumentCreateBDSNav.js",
			"Visible": true
		},
		{
			"Title": "$(L,add_activity)",
			"OnPress": "/SAPAssetManager/Rules/Notifications/Activity/CreateUpdate/NotificationActivityCreateNav.js",
			"Visible": "/SAPAssetManager/Rules/WorkOrders/Details/IsServiceOrder.js",
			"Enabled": "/ZSAPAssetManager/Rules/WorkOrders/Details/ZIsNotificationAvailable.js"
		},
		{
			"Title": "$(L,add_serial_number)",
			"OnPress": "/ZSAPAssetManager/Rules/Notifications/Activity/ZNotificationActivityCreateNav.js",
			"Visible": "/ZSAPAssetManager/Rules/WorkOrders/ZSerialNumberAddVisible.js"
		}
	]
}